#!/usr/bin/env python3
"""Replace a substring in each selected file's name (plain text, not regex)."""
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from _helpers import get_selected_paths, report, safe_rename, zenity_entry

search = zenity_entry("Replace", "Search for:")
if not search:
    sys.exit()
replace = zenity_entry("Replace", "Replace with (empty = delete):")
if replace is None:
    sys.exit()

failed = 0
unchanged = 0
for src in get_selected_paths():
    new_name = src.name.replace(search, replace)
    if new_name == src.name:
        unchanged += 1
        continue
    if not safe_rename(src, src.with_name(new_name)):
        failed += 1

report("Replace", {
    "Skipped (target exists)": failed,
    "No match": unchanged,
})
