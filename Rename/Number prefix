#!/usr/bin/env python3
"""Add a sequential numeric prefix to selected files.

  Order:     Nautilus selection order (as passed by the file manager)
  Separator: '_'
  Start:     0
  Width:     auto, zero-padded to fit the largest index (minimum 2 digits)

  5 files  -> 00_, 01_, 02_, 03_, 04_
  100 files -> 00_, 01_, ..., 99_
  101 files -> 000_, 001_, ..., 100_
"""
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from _helpers import get_selected_paths, report, safe_rename

files = get_selected_paths()
if not files:
    sys.exit()

width = max(2, len(str(len(files) - 1)))

failed = 0
for i, src in enumerate(files):
    num = f"{i:0{width}d}"
    if not safe_rename(src, src.with_name(f"{num}_{src.name}")):
        failed += 1

report("Number prefix", {"Skipped (target exists)": failed})
