#!/usr/bin/env python3
"""Remove a leading prefix up to and including the first separator (default '_').

  01_file.mp4        -> file.mp4
  abc_report.pdf     -> report.pdf
  file.mp4           -> file.mp4         (no separator: skipped)
  _file.mp4          -> _file.mp4        (empty prefix: skipped)
"""
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from _helpers import get_selected_paths, report, safe_rename, zenity_entry

sep = zenity_entry("Remove prefix", "Separator that ends the prefix:", "_")
if not sep:
    sys.exit()

failed = 0
unchanged = 0
for src in get_selected_paths():
    prefix, found, rest = src.name.partition(sep)
    if not found or not prefix:
        unchanged += 1
        continue
    if not safe_rename(src, src.with_name(rest)):
        failed += 1

report("Remove prefix", {
    "Skipped (target exists)": failed,
    "No prefix found": unchanged,
})
